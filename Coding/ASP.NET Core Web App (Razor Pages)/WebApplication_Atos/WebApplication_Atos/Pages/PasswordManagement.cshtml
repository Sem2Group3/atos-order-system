@page
@model PasswordManagementModel
@{
    ViewData["Title"] = "Set Employee Password (Dev Only)";
}

<style>
    /* Outer layout: row on wide screens so image appears to the right.
           Keeps the whole block centered on the page via max-width + auto margins. */
    .dev-layout {
        display: flex;
        flex-direction: row; /* row for desktop so image sits to the right */
        justify-content: center; /* center the group as a whole */
        align-items: flex-start; /* align items to the top */
        gap: 3rem;
        margin: 2rem auto;
        max-width: 1100px;
        padding: 0 1rem;
    }

    /* Form container: fixed maximum width, will take available space but won't grow too large */
    .dev-container {
        flex: 0 1 520px; /* do not force-grow, can shrink slightly, basis 520px */
    }

        .dev-container h2 {
            margin-bottom: 1rem;
        }

    .dev-form div {
        margin-bottom: 0.75rem;
    }

    .dev-form label {
        display: block;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }

    .dev-form input,
    .dev-form select {
        width: 100%;
        padding: 0.4rem;
        box-sizing: border-box;
    }

    .dev-info {
        background-color: #f4f6f8;
        border-left: 4px solid #999;
        padding: 0.75rem 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

        .dev-info strong {
            display: block;
            margin-bottom: 0.25rem;
        }

    .dev-result {
        margin-top: 1rem;
        font-weight: 600;
    }

    /* Image column: keep its natural size and align to the top of the form.
           This places it to the right of the form when in row layout. */
    .dev-image {
        flex: 0 0 auto; /* do not grow or shrink */
        align-self: flex-start;
        display: flex;
        align-items: flex-start;
        justify-content: center;
    }

        .dev-image img {
            max-width: 350px;
            width: 100%;
            height: auto;
            display: block;
        }

        .dev-layout {
        flex-direction: column;
        align-items: center;
    }

    .dev-container {
        width: 100%;
        max-width: 520px;
    }

    .dev-image {
        margin-top: 1.5rem;
    }

        .dev-image img {
            max-width: 100%;
        }
</style>

<div class="dev-layout">
    <div class="dev-container">
        <h2>Set Employee Password</h2>

        <div class="dev-info">
            <strong>Note</strong>
            Because passwords are only stored as hashes you wouldn't be able to find the password
            anymore if you forgot it. This page will allow you to reassign passwords
            to employees, meant for development only. It's also a temporary workaround since there's no
            registration system yet.
            <br />
            <p style="font-weight: 500;">
                Scroll down to see a visual representation of the login flow
                (and the general flow between layers for most functions).
            </p>
            <br />
            <strong>Important:</strong>
            <ul>
                <li>Intended for development environments only</li>
                <li>This page has no security and doesn't even require you to be logged in</li>
                <li>Input password is automatically hashed and stored in the database</li>
                <li style="color:red">This page should be removed or secured before production</li>
            </ul>
        </div>

        <form method="post" class="dev-form">
            <div>
                <label asp-for="SelectedUsername">Employee</label>
                <select asp-for="SelectedUsername">
                    <option value="">-- select employee --</option>
                    @foreach (var employee in Model.Employees)
                    {
                        <option value="@employee.Werknemer">@employee.Werknemer</option>
                    }
                </select>
            </div>

            <div>
                <label asp-for="Password">New password</label>
                <input asp-for="Password" />
            </div>

            <div>
                <label asp-for="ConfirmPassword">Confirm password</label>
                <input asp-for="ConfirmPassword" />
            </div>

            <button type="submit">Set Password</button>
        </form>

        @if (Model.ResultMessage != null)
        {
            <div class="dev-result">
                @Model.ResultMessage
            </div>
        }
    </div>

    <div class="dev-image">
        <img src="~/img/Login Flow Diagram.png" alt="Login Flow Diagram" />
    </div>
</div>

