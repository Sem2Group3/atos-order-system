    <script>
        function showTable(tableKey) {
            const tableIds = [
                "Offerte vlag-mast",
                "Offerte bedrukte vlag",
                "Order Vlag-mast",
                "Order bedrukte-vlag",
                "Huurcontract",
                "Factuur",
                "Herinnering",
                "Winkel"
            ];

            tableIds.forEach(id => {
                const el = document.getElementById(id);
                if (el) el.style.display = (id === tableKey) ? "block" : "none";
            });

            document.querySelectorAll(".flag-button").forEach(btn => {
                btn.classList.remove("active");
                if (btn.textContent.trim() === tableKey) {
                    btn.classList.add("active");
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.flag-button').forEach(button => {
                button.addEventListener('click', function() {
                    // prevent access if user doesn't have authority
                    if (this.disabled) {
                        return; // Stop the function if the button is natively disabled
                    }

                    const tableKey = this.getAttribute('data-table-key');
                    if (tableKey) {
                        showTable(tableKey);
                    }
                });
            });
        });
    </script>


</body>




