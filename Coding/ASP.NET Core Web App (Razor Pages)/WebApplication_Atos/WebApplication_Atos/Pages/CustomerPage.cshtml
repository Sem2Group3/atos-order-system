<div class="modal fade" id="PrijsopgaveModal" tabindex="-1" aria-labelledby="PrijsopgaveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Prijsopgave voor accessoires</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table table-bordered table-sm table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th></th>
                            <th>Prijsopgave</th>
                            <th>Datum prijsopgave</th>
                            <th>Netto</th>
                            <th>Btw</th>
                            <th>Bruto</th>
                            <th>Levertijd</th>
                            <th>Geprint</th>
                            <th>Bijzonderheden</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var offerte in Model.UserOrders)
                        {
                            <tr>
                                <td>
                                    <form method="post" asp-page-handler="NewOrderFlagPrijsopgave">
                                        <input type="hidden" name="serializedOrder" value="@Model.SerializeOrder(offerte)" />
                                        <button type="submit">Selecteer</button>
                                    </form>
                                </td>
                                <td>@offerte.PrijsopgaveId</td>
                                <td>@offerte.DatumPrijsopgave?.ToString("dd-MMM-yy")</td>
                                <td>€ @Model.CalculateNetto(offerte).ToString("F2")</td>
                                <td>@offerte.BTW?.ToString("P0")</td>
                                <td>€ @((Model.CalculateNetto(offerte) * (1 + (double)offerte.BTW)).ToString("F2"))</td>
                                <td>@offerte.Levertijd</td>
                                <td>@offerte.Geprint</td>
                                <td>@offerte.Bijzonderheden</td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="PrijsopgaveModal2" tabindex="-1" aria-labelledby="PrijsopgaveModalLabel2" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Prijsopgave voor accessoires</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table table-bordered table-sm table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th></th>
                            <th>Prijsopgave</th>
                            <th>Datum prijsopgave</th>
                            <th>formaat</th>
                            <th>type</th>
                            <th>kleuren</th>
                            <th>Aantal</th>
                            <th>prijs</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var offerte in Model.CurrentClientFlagQuotes)
                        {
                            foreach (var rule in Model.GetFlagQuotationRules(offerte))
                            {
                                var ruleJson = Model.SerializePrintedFlagRule(rule);
                                var offerteJson = Model.SerializePrintedFlag(offerte);
                                <tr>
                                    <td>
                                        <form method="post" asp-page-handler="NewPrintedFlagPrijsopgave" onsubmit="return attachNaamVlag(this);">
                                            <input type="hidden" name="serializedPrintedFlagRule" value="@ruleJson" />
                                            <input type="hidden" name="serializedPrintedFlag" value="@offerteJson" />
                                            <input type="hidden" name="NaamVlag" />
                                            <button type="submit">Selecteer</button>
                                        </form>
                                    </td>
                                    <td>@rule.PrijsopgaveId</td>
                                    <td>@offerte.DatumPrijsopgave?.ToString("dd-MMM-yy")</td>
                                    <td>@rule.Formaat</td>
                                    <td>@rule.Type</td>
                                    <td>@rule.Kleuren</td>
                                    <td>@rule.Hoeveelheid</td>
                                    <td>@rule.Prijs.ToString("F2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

                <div class="mt-3">
                    <label for="globalNaamVlagInput">Naam vlag:</label>
                    <input id="globalNaamVlagInput" type="text" class="form-control" value=""/>
                </div>
            </div>

        </div>
    </div>
</div>
<script>
    function attachNaamVlag(form) {
        const naamVlagInput = document.getElementById("globalNaamVlagInput");
        const hiddenInput = form.querySelector("input[name='NaamVlag']");
        hiddenInput.value = naamVlagInput.value;

        if (hiddenInput.value.trim() !== "") {
            return true;
        }

        alert("Naam van de vlag invullen, aub");
        return false;
    }
</script>
}