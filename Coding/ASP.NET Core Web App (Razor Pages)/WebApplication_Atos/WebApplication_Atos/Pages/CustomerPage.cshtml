                                <td><form method="post" asp-page-handler="EditFlagQuote"><button class="flag-button" type="submit" name="PrijsopgaveId" value="@quotes.PrijsopgaveId">Edit</button></form></td>
                                <td>@quotes.DatumPrijsopgave?.ToString("dd-MMM-yy")</td>
                                <td>@quotes.Bijzonderheden</td>
                                <td>@quotes.ContactPersoon</td>
                                <td>@quotes.EmailAdres</td>
                                <td>@Model.GetEmployeeName(quotes.WerknemerId)</td>
