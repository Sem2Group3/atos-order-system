        <div class="flags">
            @{
                bool hasFinanceRole = User.IsInRole("finance");
                bool hasOrdersRole = User.IsInRole("orders");
                bool hasProduceRole = User.IsInRole("produce");
                
                bool canAccessOffertes = hasOrdersRole;
                bool canAccessOrders = hasProduceRole;
                bool canAccessHuurconctract = hasFinanceRole;
                bool canAccessFactuur = hasFinanceRole;
                bool canAccessHerinnering = hasFinanceRole;
                bool canAccessWinkel = true;
            }

                <button class="flag-button @(canAccessOffertes ? "" : "disabled-tab")" data-table-key="Offerte vlag-mast" @(canAccessOffertes ? "" : "disabled")>
                Offerte vlag-mast
            </button>
            <button class="flag-button @(canAccessOffertes ? "" : "disabled-tab")" data-table-key="Offerte bedrukte vlag" @(canAccessOffertes ? "" : "disabled")>
                Offerte bedrukte vlag
            </button>
            <button class="flag-button @(canAccessOrders ? "" : "disabled-tab")" data-table-key="Order Vlag-mast" @(canAccessOrders ? "" : "disabled")>
                Order vlag - mast
            </button>
            <button class="flag-button @(canAccessOrders ? "" : "disabled-tab")" data-table-key="Order bedrukte-vlag" @(canAccessOrders ? "" : "disabled")>
                Order bedrukte vlag
            </button>
            <button class="flag-button @(canAccessHuurconctract ? "" : "disabled-tab")" data-table-key="Huurcontract" @(canAccessHuurconctract ? "" : "disabled")>
                Huurcontract
            </button>
            <button class="flag-button @(canAccessFactuur ? "" : "disabled-tab")" data-table-key="Factuur" @(canAccessFactuur ? "" : "disabled")>
                Factuur
            </button>
            <button class="flag-button @(canAccessHerinnering ? "" : "disabled-tab")" data-table-key="Herinnering" @(canAccessHerinnering ? "" : "disabled")>
                Herinnering
            </button>
            <!-- nog geen autoriteit op winkel pagina geimplementeerd -->
            <button class="flag-button" @(canAccessWinkel ? "" : "disabled-tab")" data-table-key="Winkel" @(canAccessWinkel ? "" : "disabled")>
                Winkel
            </button>

        </div>

        <div id="Offerte vlag-mast" class="table-wrapper tableExcel" style="display: none;">
            <table>
                <thead>
                    <tr>
                        <th></th>
                        <th>Datum</th>
                        <th>Referentie</th>
                        <th>Contactpersoon</th>
                        <th>E-mail gestuurd naar</th>
                        <th>Werknemer</th>
                    </tr>
                </thead>
                <tbody>
                        @if (Model.CurrentClientFlagQuotes != null && Model.CurrentClientFlagQuotes.Any())
                    {
                        foreach (var quotes in Model.CurrentClientFlagQuotes)
                        {
                            <tr>
                                <td><form method="post" asp-page-handler="EditPrijsogave"><button class="flag-button" type="submit" name="PrijsopgaveId" value="@quotes.PrijsopgaveId">Edit</button></form></td>
                                <td>@quotes.DatumPrijsopgave?.ToString("dd-MMM-yy")</td>
                                <td>@quotes.ReferentieText</td>
                                <td>@quotes.ContactPersoon</td>
                                <td>@quotes.EmailAdres</td>
                                <td>@(User.Identity?.Name ?? "—")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6">Geen bestellingen gevonden voor deze klant.</td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="bottom-actions">
                <form method="post" asp-page-handler="NewPrijsopgave">
                    <button class="new-quote-button">Nieuwe prijsopgave..</button>
                </form>
            </div>

        </div>

        <div id="Offerte bedrukte vlag" class="table-wrapper tableExcel" style="display: none;">
            <table>
                <thead>
                    <tr>
                        <th></th>
                        <th>Datum</th>
                        <th>Referintie</th>
                        <th>Contactpersoon</th>
                        <th>E-mail adres</th>
