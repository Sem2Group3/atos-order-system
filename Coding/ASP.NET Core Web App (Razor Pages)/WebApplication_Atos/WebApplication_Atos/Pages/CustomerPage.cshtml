@page
@model WebApplication_Atos.Pages.CustomerPageModel
@{
<link rel="stylesheet" href="~/css/customer.css?v=2" />

<img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQaTTlsqOihcptniZAoB9yIQzsuUkRXVwe9oQ&s" alt="Atos Logo">
<body>
    <div class="customer-data-container">
        <div class="header">
            <span class="title">Klantgegevens</span>
        </div>
        <form method="post">
            <div class="form-sections-container">
                <div class="customer-info-wrapper">
                    <div class="form-grid">
                        <div class="form-row">
                            <label for="customerNumber">Klantnummer</label>
                            <div class="input-group">
                                <input asp-for="currentClient.Klantid" type="text" readonly />
                                @if (!Model.changeMode)
                                {
                                    <button class="small-button" type="submit" name="postString" value="EnterEditMode">Verander ...</button>
                                }
                                else
                                {
                                    <button class="small-button" type="submit" name="postString" value="SaveChanges">Wijzigingen opslaan</button>
                                }
                                <input type="hidden" name="changeMode" value="@Model.changeMode" />

                                @if (Model.currentClientID == 0)
                                {
                                    <button type="submit" name="postString" value="SaveClientButtonClick">Opslaan</button>
                                }
                                else
                                {
                                    <button type="submit" name="postString" value="NewClientButtonClick">Nieuw</button>
                                }
                            </div>

                            <button class="small-button" type="button" data-bs-toggle="modal" data-bs-target="#SearchCustomerModal">Zoeken</button>
                            <input type="text" id="SearchedClient" value="" readonly />
                        </div>
                        @if (Model.changeMode == true)
                        {
                            <div class="form-row">
                                <label>Naam</label>
                                <input asp-for="currentClient.Naam" type="text" />
                                <label class="right-label">Uitstaand Bedrag</label>
                                <input type="text" id="OutstandingMoney" value="" />
                            </div>

                            <div class="form-row">
                                <label>Adres</label>
                                <input asp-for="currentClient.Adres" type="text" />
                                <label class="right-label">Telefoonnummer</label>
                                <input asp-for="currentClient.Fax" type="text" />
                            </div>

                            <div class="form-row">
                                <label>Postcode</label>
                                <input asp-for="currentClient.Postcode" type="text" />
                                <label class="right-label">Mobiel</label>
                                <input asp-for="currentClient.Telefoon" type="text" />
                            </div>

                            <div class="form-row">
                                <label>Woonplaats</label>
                                <input asp-for="currentClient.Woonplaats" type="text" />
                                <label class="right-label">E-mailadres</label>
                                <input asp-for="currentClient.Email" type="email" />
                            </div>

                            <div class="form-row">
                                <input type="text" value="" />
                                <button class="small-button">Zoek artikel</button>
                                <label class="right-label">Post voor de aandacht van</label>
                                <input asp-for="currentClient.Contactpersoon" type="text" />
                            </div>

                            <div class="form-row">
                                <label>Noities</label>
                                <textarea asp-for="currentClient.Notities"></textarea>
                            </div>

                            <div class="form-row">
                                <label>Geblokkeerd</label>
                                <select asp-for="currentClient.Geblokkeerd">
                                    <option value="Yes">Ja</option>
                                    <option value="No">Nee</option>
                                </select>
                            </div>

                            <div class="form-row">
                                <div></div>
                            </div>

                            <div class="form-row">
                                <div></div>
                            </div>
                        }
