@{
    ViewData["Title"] = "Toegang geweigerd";
}

<div class="container mt-5 text-center">
    <h1 class="text-danger">Toegang geweigerd</h1>

    <p class="mt-3">
        U hebt geen toestemming voor toegang tot deze pagina.
    </p>

    @if (Context.Request.Query.ContainsKey("ReturnUrl"))
    {
        <p class="text-muted">
            Poging tot pad: <code>@Context.Request.Query["ReturnUrl"]</code>
        </p>
    }
    
    <a class="btn btn-primary mt-3" asp-controller="Home" asp-action="Index">Terug naar startpagina</a>
</div>