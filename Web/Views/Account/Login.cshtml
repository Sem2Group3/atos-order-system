@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<h2>Login</h2>

<form asp-action="Login" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="form-check mb-3 d-flex align-items-center gap-2">

        <input asp-for="RememberMe" class="form-check-input" />

        <label asp-for="RememberMe"
               class="form-check-label mb-0">
            Remember me
        </label>

        <i class="bi bi-question-circle text-muted"
           role="button"
           tabindex="0"
           data-bs-toggle="tooltip"
           data-bs-placement="right"
           title="Keeps you signed in on this device for a longer period of time">
        </i>

    </div>
    
    <button type="submit" id="submit-button" class="btn btn-primary">Login</button>
</form>

<div class="mt-3">
    <p>
        Don’t have an account?
        <a asp-controller="Account" asp-action="Register">Register here</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            $('[data-bs-toggle="tooltip"]').tooltip()
        })
    </script>
}
