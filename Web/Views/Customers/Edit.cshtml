@model Web.Models.CustomerViewModel

@{
    ViewData["Title"] = "Klant bewerken";
}

<h1>Klant bewerken</h1>

<div class="row">
    <div class="col-lg-10">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <!-- Left Column: Customer Information -->
                <div class="col-lg-6">
                    <h4>Klantgegevens</h4>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Street" class="form-label"></label>
                        <input asp-for="Street" class="form-control" />
                        <span asp-validation-for="Street" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="HouseNumber" class="form-label"></label>
                            <input asp-for="HouseNumber" class="form-control" />
                            <span asp-validation-for="HouseNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PostalCode" class="form-label"></label>
                            <input asp-for="PostalCode" class="form-control" />
                            <span asp-validation-for="PostalCode" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-4 mb-3">
                            <label asp-for="City" class="form-label"></label>
                            <input asp-for="City" class="form-control" />
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label"></label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MailAddressedTo" class="form-label"></label>
                        <input asp-for="MailAddressedTo" class="form-control" />
                        <span asp-validation-for="MailAddressedTo" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                </div>

                <!-- Right Column: Invoice Information -->
                <div class="col-lg-6">
                    <h4>Factuurgegevens</h4>

                    <div class="mb-3">
                        <label asp-for="InvoiceInformation.Name" class="form-label"></label>
                        <input asp-for="InvoiceInformation.Name" class="form-control" />
                        <span asp-validation-for="InvoiceInformation.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="InvoiceInformation.Street" class="form-label"></label>
                        <input asp-for="InvoiceInformation.Street" class="form-control" />
                        <span asp-validation-for="InvoiceInformation.Street" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="InvoiceInformation.HouseNumber" class="form-label"></label>
                            <input asp-for="InvoiceInformation.HouseNumber" class="form-control" />
                            <span asp-validation-for="InvoiceInformation.HouseNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="InvoiceInformation.PostalCode" class="form-label"></label>
                            <input asp-for="InvoiceInformation.PostalCode" class="form-control" />
                            <span asp-validation-for="InvoiceInformation.PostalCode" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="InvoiceInformation.City" class="form-label"></label>
                            <input asp-for="InvoiceInformation.City" class="form-control" />
                            <span asp-validation-for="InvoiceInformation.City" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="InvoiceInformation.InvoiceRegarding" class="form-label"></label>
                        <input asp-for="InvoiceInformation.InvoiceRegarding" class="form-control" />
                        <span asp-validation-for="InvoiceInformation.InvoiceRegarding" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="InvoiceInformation.VatNumber" class="form-label"></label>
                        <input asp-for="InvoiceInformation.VatNumber" class="form-control" />
                        <span asp-validation-for="InvoiceInformation.VatNumber" class="text-danger"></span>
                    </div>

                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Opslaan</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary ms-2">Annuleren</a>
            </div>
        </form>

        @if (User.HasClaim("permission", "customer.delete"))
        {
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-3" onsubmit="return confirm('Weet u zeker dat u deze klant wilt verwijderen?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Verwijderen</button>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}







