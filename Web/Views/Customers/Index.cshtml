@model List<Web.Models.CustomerViewModel>

@{
    ViewData["Title"] = "Klanten";
}

<h1>Klanten</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="row mb-3">
    <div class="col-md-8">
        <form method="get" asp-action="Index" class="input-group">
            <input type="text" name="searchTerm" class="form-control" placeholder="Zoek klant op naam of e-mail..." value="@ViewData["SearchTerm"]" />
            <button type="submit" class="btn btn-outline-secondary">
                <i class="bi bi-search"></i> Zoeken
            </button>
        </form>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus"></i> Nieuwe klant
        </a>
    </div>
</div>

@if (Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>Naam</th>
                    <th>E-mail</th>
                    <th>Telefoon</th>
                    <th>Plaats</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model)
                {
                    <tr style="cursor: pointer;" onclick="window.location='@Url.Action("Details", "Customers", new { id = customer.Id })'">
                        <td>@customer.FullName</td>
                        <td>@customer.Email</td>
                        <td>@customer.PhoneNumber</td>
                        <td>@customer.City</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <p class="text-muted">Geen klanten gevonden. Gebruik de knop "Nieuwe klant" om een klant toe te voegen.</p>
        </div>
    </div>
}
